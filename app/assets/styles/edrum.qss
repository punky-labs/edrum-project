/* =============================================================================
   eDrum Config — Product Stylesheet
   Extends: boal_base.qss

   Product-specific overrides and component styles for the eDrum Config app.
   Generic widget styles live in boal_base.qss; only eDrum-specific
   components and overrides belong here.
============================================================================= */


/* ---------------------------------------------------------------------------
   Toolbar — eDrum-specific layout
--------------------------------------------------------------------------- */

QToolBar QLabel {
    color: #6b6b6b;
    font-size: 10px;
    padding: 0 4px;
}


/* ---------------------------------------------------------------------------
   Connection status dot
--------------------------------------------------------------------------- */

QLabel#status_dot {
    font-size: 14px;
    padding: 0 4px;
}


/* ---------------------------------------------------------------------------
   Pad Config tab — left panel (inputs sidebar)
--------------------------------------------------------------------------- */

QWidget#left_panel {
    background-color: #1e1e1e;
    border-right: 1px solid #2a2a2a;
}

/* "INPUTS" section label */
QLabel#section_label {
    color: #6b6b6b;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 2px;
    font-family: "IBM Plex Sans", sans-serif;
    text-transform: uppercase;
}


/* ---------------------------------------------------------------------------
   Input cards
--------------------------------------------------------------------------- */

#InputCard {
    background-color: #252525;
    border: none;
    border-radius: 10px;
}

#InputCard:hover {
    background-color: #2a2a2a;
}

/* Selected state — subtle background lift only */
#InputCard[selected="true"] {
    background-color: #2a2a2a;
}

/* Reserved / greyed */
#InputCard[reserved="true"] {
    background-color: #1e1e1e;
    border-color: #222222;
}

#InputCard QLabel {
    background: transparent;
}

#InputCard QLabel#card_num_label {
    font-size: 28px;
    font-weight: 700;
    color: #3a3a3a;
    background: transparent;
}

#InputCard QLabel#card_name_label {
    font-size: 11px;
    font-weight: 600;
}


/* ---------------------------------------------------------------------------
   Autotrack button — bottom of left panel
--------------------------------------------------------------------------- */

QPushButton#autotrack_btn {
    background-color: #1e1e1e;
    color: #6b6b6b;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    padding: 5px 10px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1.5px;
}

QPushButton#autotrack_btn:checked {
    background-color: #00aabb;
    color: #ffffff;
    border-color: #00aabb;
}


/* ---------------------------------------------------------------------------
   Group boxes — eDrum section cards
   (Velocity Curve, Hit Log, Trigger Settings override base radius/bg)
--------------------------------------------------------------------------- */

QGroupBox {
    background-color: #1e1e1e;
    border: 1px solid #2a2a2a;
    border-radius: 10px;
}


/* ---------------------------------------------------------------------------
   Velocity bar (QProgressBar inside curve panel)
--------------------------------------------------------------------------- */

QWidget#vel_col {
    background-color: #1e1e1e;
}

QProgressBar#vel_bar {
    background-color: #1a1a1a;
    border: none;
    border-radius: 3px;
}

QProgressBar#vel_bar::chunk {
    background-color: #00aabb;
    border-radius: 2px;
}


/* ---------------------------------------------------------------------------
   Slider value labels (the numeric readout above each slider)
--------------------------------------------------------------------------- */

QLabel#slider_value {
    color: #d8d4ce;
    background: transparent;
    border: none;
    padding: 1px 4px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10px;
    font-weight: 600;
}


/* ---------------------------------------------------------------------------
   Slider param labels (text below each slider: "Threshold", "Scan Time" etc)
--------------------------------------------------------------------------- */

QLabel.slider_label {
    color: #6b6b6b;
    font-size: 9px;
    font-family: "IBM Plex Sans", sans-serif;
}


/* ---------------------------------------------------------------------------
   MIDI monitor strip (bottom of MIDI panel)
--------------------------------------------------------------------------- */

QLabel#midi_monitor {
    color: #00aabb;
    background-color: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    padding: 4px 12px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 12px;
    font-weight: 600;
}


/* ---------------------------------------------------------------------------
   MIDI tab widget
--------------------------------------------------------------------------- */

QTabWidget#midi_tabs::pane {
    background-color: #1e1e1e;
    border: 1px solid #2a2a2a;
    border-radius: 0 6px 6px 6px;
}


/* ---------------------------------------------------------------------------
   Connect / Disconnect button states
--------------------------------------------------------------------------- */

QPushButton#btn_connect_toggle {
    min-width: 110px;
}

QPushButton#btn_connect_toggle[connected="true"] {
    background-color: #1e2e1e;
    color: #2ecc71;
    border-color: #2ecc71;
}


/* ---------------------------------------------------------------------------
   Pad config tab — right panel placeholder
--------------------------------------------------------------------------- */

QLabel#placeholder_label {
    color: #3a3a3a;
    font-size: 13px;
    font-family: "IBM Plex Sans", sans-serif;
}
